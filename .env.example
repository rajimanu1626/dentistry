# =============================================================================
# clinic-crm — environment variables (copy to .env and fill in)
# All third-party endpoints are env-var driven for portability (Supabase -> AWS).
# =============================================================================

# --- App ---
APP_ENV=development            # development | test | staging | production
APP_NAME=clinic-crm
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# --- Database (portable across Supabase / RDS / local Postgres) ---
DATABASE_URL=postgresql+asyncpg://crm:crm@localhost:5432/crm
DATABASE_URL_SYNC=postgresql+psycopg://crm:crm@localhost:5432/crm  # for Alembic
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# --- Signup policy ---
# closed | invite | bootstrap | open
# Production: use "invite" (join via clinic invite; first owner when DB is empty).
SIGNUP_MODE=invite
INVITE_DEFAULT_TTL_SECONDS=604800

# --- Identity / Auth (portable across Supabase Auth / Cognito / Keycloak) ---
# In dev, set IDENTITY_PROVIDER=local to use the built-in JWT signer.
IDENTITY_PROVIDER=local        # local | supabase | cognito
JWT_ISSUER=clinic-crm-local
JWT_AUDIENCE=clinic-crm
JWT_SIGNING_KEY=change-me-in-prod-use-32-byte-random
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
# For supabase/cognito: validate via JWKS endpoint
JWKS_URL=
JWKS_CACHE_TTL_SECONDS=3600

# --- Object storage (portable across Supabase Storage / MinIO / S3) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=clinic-crm-dev
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniominio
S3_PUBLIC_BASE_URL=               # optional; if unset, signed URLs are used always
S3_SIGNED_URL_TTL_SECONDS=60
S3_FORCE_PATH_STYLE=true          # required for MinIO

# --- Security ---
# 32-byte key (base64) for pgcrypto column-level encryption of PHI fields.
PHI_ENCRYPTION_KEY=replace-with-base64-32-bytes
# HMAC secret for external share-link tokens (so a DB dump alone is useless).
EXTERNAL_SHARE_HMAC_SECRET=replace-with-base64-32-bytes
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- External share links ---
EXTERNAL_SHARE_DEFAULT_TTL_SECONDS=86400   # 24h
EXTERNAL_SHARE_MAX_TTL_SECONDS=604800      # 7d
EXTERNAL_SHARE_MAX_VIEWS=5
EXTERNAL_SHARE_MAX_PASSWORD_ATTEMPTS=5

# --- Email (mailhog locally) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@clinic-crm.local
SMTP_USE_TLS=false

# --- Rate limiting ---
RATE_LIMIT_STORAGE_URI=memory://   # or redis://localhost:6379/0
